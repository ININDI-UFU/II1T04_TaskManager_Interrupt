sde o boot. Não bloqueia nada!</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1500" b="1" dirty="0"><a:solidFill><a:srgbClr val="6C63FF"/></a:solidFill></a:rPr><a:t>Padrão fundamental:</a:t></a:r></a:p><a:p><a:pPr marL="457200" indent="-228600"><a:spcBef><a:spcPts val="150"/></a:spcBef><a:buFont typeface="Arial"/><a:buChar char="1"/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1400" dirty="0"><a:solidFill><a:srgbClr val="D0D0E0"/></a:solidFill></a:rPr><a:t>Guardar o </a:t></a:r><a:r><a:rPr lang="pt-BR" sz="1400" b="1" dirty="0"><a:solidFill><a:srgbClr val="FFC857"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>tempoAnterior</a:t></a:r><a:r><a:rPr lang="pt-BR" sz="1400" dirty="0"><a:solidFill><a:srgbClr val="D0D0E0"/></a:solidFill></a:rPr><a:t> (unsigned long)</a:t></a:r></a:p><a:p><a:pPr marL="457200" indent="-228600"><a:spcBef><a:spcPts val="150"/></a:spcBef><a:buFont typeface="Arial"/><a:buChar char="2"/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1400" dirty="0"><a:solidFill><a:srgbClr val="D0D0E0"/></a:solidFill></a:rPr><a:t>A cada loop, calcular: </a:t></a:r><a:r><a:rPr lang="pt-BR" sz="1400" b="1" dirty="0"><a:solidFill><a:srgbClr val="00D9A6"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>millis() - tempoAnterior</a:t></a:r></a:p><a:p><a:pPr marL="457200" indent="-228600"><a:spcBef><a:spcPts val="150"/></a:spcBef><a:buFont typeface="Arial"/><a:buChar char="3"/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1400" dirty="0"><a:solidFill><a:srgbClr val="D0D0E0"/></a:solidFill></a:rPr><a:t>Se diferença ≥ intervalo desejado → executar ação</a:t></a:r></a:p><a:p><a:pPr marL="457200" indent="-228600"><a:spcBef><a:spcPts val="150"/></a:spcBef><a:buFont typeface="Arial"/><a:buChar char="4"/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1400" dirty="0"><a:solidFill><a:srgbClr val="D0D0E0"/></a:solidFill></a:rPr><a:t>Atualizar </a:t></a:r><a:r><a:rPr lang="pt-BR" sz="1400" b="1" dirty="0"><a:solidFill><a:srgbClr val="FFC857"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>tempoAnterior = millis()</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1500" b="1" dirty="0"><a:solidFill><a:srgbClr val="FFC857"/></a:solidFill></a:rPr><a:t>⚠ Tipo: unsigned long (32 bits) → overflow em ~49 dias</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:buNone/></a:pPr><a:r><a:rPr lang="pt-BR" sz="1400" dirty="0"><a:solidFill><a:srgbClr val="B8B8CC"/></a:solidFill></a:rPr><a:t>A subtração </a:t></a:r><a:r><a:rPr lang="pt-BR" sz="1400" b="1" dirty="0"><a:solidFill><a:srgbClr val="00D9A6"/></a:solidFill><a:latin typeface="Consolas"/></a:rPr><a:t>millis() - prev</a:t></a:r><a:r><a:rPr lang="pt-BR" sz="1400" dirty="0"><a:solidFill><a:srgbClr val="B8B8CC"/></a:solidFill></a:rPr><a:t> funciona corretamente mesmo com overflow!</a:t></a:r></a:p></p:txBody></p:sp></p:spTree><p:extLst><p:ext uri="{BB962C8B-B14F-4D97-AF65-F5344CB8AC3E}"><p14:creationId xmlns:p14="http://schemas.microsoft.com/office/powerpoint/2010/main" val="984465042"/></p:ext></p:extLst></p:cSld><p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr></p:sld>